# Copy to terraform.tfvars (never commit secrets).

location            = "eastasia"
resource_group_name = "CLOUD_PROJECT_EXAMPLE"

postgres_server_name = "taskmanagerpgexample"
postgres_database_name = "taskmanager"

postgres_admin_username = "taskadmin"
postgres_admin_password = "CHANGE_ME_STRONG_PASSWORD"

log_analytics_workspace_name = "law-taskmanager-example"
application_insights_name    = "insights-taskmanager-example"

app_service_plan_name = "ASP-taskmanager-example"
linux_web_app_name    = "taskmanager-api-example"

cors_origins_csv = "https://your-static-web-app.azurestaticapps.net,http://localhost:8080"

api_secret_key          = "CHANGE_ME_LONG_RANDOM_SECRET"
api_refresh_secret_key  = "" # Leave empty to reuse api_secret_key
admin_emails_csv        = "you@example.com"
