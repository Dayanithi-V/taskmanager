# Copy this file to .env for local development.
# In Azure App Service, set these as Application Settings instead.

# Local fallback can remain SQLite:
# DATABASE_URL=sqlite:///./smart_task_manager.db

# Azure PostgreSQL example:
DATABASE_URL=postgresql+psycopg://USERNAME:PASSWORD@HOST:5432/DBNAME?sslmode=require

SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
# Optional: separate signing key for refresh tokens (defaults to SECRET_KEY when unset).
REFRESH_SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated admin emails -> role "admin" on registration (case-insensitive).
ADMIN_EMAILS=

# Comma-separated list of allowed origins:
# Example for local + Azure Static Web App + Docker frontend (nginx on 8080)
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080,https://your-app-name.azurestaticapps.net

# Azure Monitor / Application Insights (optional; enables OpenTelemetry export when set)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Rate limits (slowapi syntax)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=20/minute

# Logging
LOG_LEVEL=INFO

# ML prioritization
USE_ML_PRIORITIZATION=false
ML_MODEL_PATH=backend/ml/model/priority_model.joblib
